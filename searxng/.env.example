# Copy to .env and adjust if needed:
#   cp .env.example .env

# Image tag: "latest" or a pinned release, e.g. "2026.3.25-541c6c3cb"
# SEARXNG_VERSION=latest

# Host port — must match config/settings.yaml → tools.searxng_url
SEARXNG_HOST_PORT=8081
SEARXNG_BASE_URL=http://127.0.0.1:8081/

# Random string for local dev (change if exposing beyond localhost)
SEARXNG_SECRET=change-me-to-a-random-string
